# PAIOS environment template — safe placeholders only. Copy real values into the
# single git-ignored local secrets store (do NOT put real secrets here).
#
# All PAIOS secrets live in one place: .local/secrets.env (under the git-ignored
# .local/ tree). Create it from this template:
#
#   mkdir -p .local
#   cp .env.example .local/secrets.env
#   # then edit .local/secrets.env with real values
#   chmod 600 .local/secrets.env
#
# Authoritative, value-free inventory of every credential: docs/operations/credentials.md
# Machine/tool inventory: docs/operations/development-environment.md

# --- Phase 2: Telegram Daily Assistant --------------------------------------

# Telegram bot token issued by @BotFather.
TELEGRAM_BOT_TOKEN=000000000:replace-with-your-bot-token

# Comma-separated numeric Telegram chat/user IDs allowed to use the bot.
# Messages from any identity not listed here must be ignored or refused.
TELEGRAM_ALLOWED_CHAT_IDS=000000000

# Optional overrides for the local answer-synthesis model (Ollama).
# Defaults are recorded in the Phase 2 architecture ADR; only set these to
# override the documented defaults on this machine.
# OLLAMA_HOST=http://127.0.0.1:11434
# PAIOS_SYNTHESIS_MODEL=
